import csv
import json
import requests
from datetime import datetime, timedelta
from collections import defaultdict

# URL pública da sua planilha (CSV)
CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQNmTF91zBXMnWtflSM3fkSc7MX3Y0okB306m38HtL9AQkWoiWUiGK6NnJ4YhBw92U367gaCdK4z3I0/pub?output=csv'

# Baixar o CSV
resp = requests.get(CSV_URL)
resp.encoding = 'utf-8'
linhas = list(csv.DictReader(resp.text.splitlines()))

# Processar extrato
extrato = []
gastos_por_mes = defaultdict(float)
receitas_por_mes = defaultdict(float)
total_receitas = 0.0
total_gastos = 0.0
meses = set()

for row in linhas:
    try:
        data = row.get('data', '').strip()
        if not data:
            continue
        # Supondo que a data esteja no formato DD/MM/AAAA
        partes = data.split('/')
        if len(partes) == 3:
            data_iso = f"{partes[2]}-{partes[1]}-{partes[0]}"
            mes_ano = data_iso[:7]
        else:
            mes_ano = data[:7]
        valor_str = row.get('valor', '0').replace('.', '').replace(',', '.')
        valor = float(valor_str)
        descricao = row.get('descrição', '')
        categoria = row.get('categoria', 'Outros')
        tipo = row.get('tipo_registro', 'cartao')  # ou 'extrato'
        cartao = row.get('cartao_final', '') if tipo == 'cartao' else ''
        
        # Valores negativos são despesas, positivos são receitas
        if valor < 0:
            total_gastos += abs(valor)
            gastos_por_mes[mes_ano] += abs(valor)
        else:
            total_receitas += valor
            receitas_por_mes[mes_ano] += valor
        
        extrato.append({
            'data': data_iso,
            'descricao': descricao,
            'categoria': categoria,
            'cartao': cartao,
            'valor': abs(valor)  # guardamos positivo, o site usa negativo no display
        })
        meses.add(mes_ano)
    except Exception as e:
        print('Erro na linha:', row, e)

meses_ordenados = sorted(meses)

# Montar o JSON final (compatível com o que o site espera)
data = {
    "lastUpdate": datetime.now().isoformat(),
    "rendaLiquida": total_receitas,
    "totalReceitas": total_receitas,
    "totalGastos": total_gastos,
    "saldoTotal": total_receitas - total_gastos,
    "mediaDiaria": total_gastos / 30 if total_gastos else 0,
    "taxaEsforco": (total_gastos / total_receitas * 100) if total_receitas else 0,
    "capPoupanca": 0,  # você pode calcular baseado em transações específicas
    "diasReserva": 0,
    "scoreFinanceiro": 45,
    "variacaoGastoMes": 0.0,
    "gastosMensais": dict(gastos_por_mes),
    "receitasMensais": dict(receitas_por_mes),
    "gastosPorCategoria": {},
    "gastosCatMesAtual": {},
    "limitesSugeridos": {  # mantenha os limites que você já tinha
        "Alimentação": 800, "Transporte": 400, "Saúde": 400, "Lazer": 300,
        "Educação": 400, "Pet": 250, "Compras": 350, "Serviços": 250,
        "Streaming": 100, "Vestuário": 200, "Eletrônicos": 200, "Casa": 1500, "Outros": 200
    },
    "rankingCategoria": [],
    "alertas": [],
    "mesesDisponiveis": meses_ordenados,
    "debt": {  # mantenha a dívida manualmente ou calcule se tiver dados
        "valor_total": 35000,
        "saldo_devedor": 35000,
        "parcelas_pagas": 0,
        "total_parcelas": 30,
        "parcela_mensal": 500,
        "extra_semestral": 4000,
        "meses_plr": [2,8],
        "amortizacao": [],
        "proximas_parcelas": []
    },
    "extrato": extrato,
    "receitasFixas": [
        {"descricao": "Salário Principal", "valor": 1761.48, "dia_previsto": 15},
        {"descricao": "Salário Complementar", "valor": 1699.34, "dia_previsto": 15},
        {"descricao": "Salário Variável", "valor": 1819.33, "dia_previsto": 30}
    ],
    "despesasRecorrentes": [
        {"descricao": "Seguro Cartão 5217", "categoria": "Seguro", "valor": 10.41, "dia_vencimento": 20},
        {"descricao": "Anuidade Cartão 7398", "categoria": "Serviços", "valor": 35.0, "dia_vencimento": 25},
        {"descricao": "Spotify", "categoria": "Streaming", "valor": 40.9, "dia_vencimento": 10},
        {"descricao": "Google One", "categoria": "Assinatura", "valor": 9.99, "dia_vencimento": 27},
        {"descricao": "Claro Flex", "categoria": "Telefone", "valor": 39.99, "dia_vencimento": 22},
        {"descricao": "Faculdade", "categoria": "Educação", "valor": 328.67, "dia_vencimento": 24}
    ],
    "projecaoMensal": [],
    "custosEssenciais": {
        "ana_lua": [{"nome": "Leite Nan", "valor": 280}, {"nome": "Pomada", "valor": 40}, {"nome": "Lenço umedecido", "valor": 60}, {"nome": "Farmácia", "valor": 150}, {"nome": "Papinha", "valor": 50}],
        "mandelinha": [{"nome": "Fralda pet", "valor": 120}, {"nome": "Plano Pet Love", "valor": 59}]
    },
    "stats": {
        "total_gastos": total_gastos,
        "total_receitas": total_receitas,
        "total_transacoes": len(extrato),
        "meses_com_dados": len(meses_ordenados)
    }
}

# Salvar como data.json
with open('data.json', 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)

print("Arquivo data.json atualizado com sucesso!")
